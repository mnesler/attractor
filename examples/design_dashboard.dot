// Pipeline to design a new SolidJS dashboard for Attractor
digraph design_dashboard {
    graph [
        goal = "Design a comprehensive new Attractor dashboard using SolidJS and solid-ui components with dark mode, full pipeline drill-down, node execution details, inputs/outputs, token counts, and timing"
        default_max_retry = 2
        model = "google/gemini-3.1-flash-lite-preview"
    ]

    start [shape=Mdiamond, label="Start"]

    analyze_schema [shape=box, label="Analyze Current Schema",
        prompt="You are designing a new web dashboard for Attractor, an AI pipeline runner. Here is the current database schema:\n\nTables:\n1. pipelines: id, name, description, dot_content, file_path, model, created_at, updated_at\n2. runs: id, pipeline_id, pipeline_name, graph_id, graph_goal, model, status, start_time, end_time, duration_ms, total_prompt_tokens, total_completion_tokens, total_tokens, node_count, error_message, logs_root, node_logs_json\n3. node_logs: id, run_id, node_id, node_label, node_type, status, attempt_num, start_time, end_time, duration_ms, model, prompt_tokens, completion_tokens, total_tokens, notes, failure_reason\n\nREST API endpoints:\n- GET /api/pipelines - list all pipelines\n- POST /api/pipelines - create pipeline\n- GET /api/pipelines/:id - get pipeline\n- PUT /api/pipelines/:id - update pipeline\n- DELETE /api/pipelines/:id - delete pipeline\n- GET /api/pipelines/:id/runs - list runs for pipeline\n- GET /api/pipelines/:id/stats - get pipeline stats\n- PATCH /api/pipelines/:id/model - update pipeline model\n- GET /api/runs - list recent runs\n- POST /api/runs - create and start a run (accepts pipeline_id, dot_content, or prompt)\n- GET /api/runs/:id - get run with node_logs inline\n- GET /api/runs/:id/nodes - get node logs for run\n- GET /api/models - list available models\n- GET /api/stats - global stats\n\nAnalyze this schema and API surface. List every piece of data a user would want to see and interact with. Identify what inputs and outputs flow between pipeline nodes. Think about what views and components are needed for full observability."]

    design_architecture [shape=box, label="Design Component Architecture",
        prompt="Based on the schema analysis, design the SolidJS component architecture for the new Attractor dashboard. Use SolidJS with solid-ui components (from @solid-ui/core). The dashboard must have:\n\n1. A sidebar with pipeline list and global nav\n2. Dashboard overview page with stats cards, recent runs, success/fail rates\n3. Pipeline detail view showing: DOT definition, description, model, run history, per-pipeline stats\n4. Run detail view showing: status, model, duration, total tokens, goal, error messages, and a full node execution timeline\n5. Node detail panel showing: node_id, node_label, node_type, status, attempt number, start/end times, duration, model used, prompt_tokens, completion_tokens, total_tokens, notes (which contain the actual prompts/outputs), failure_reason\n6. Ability to see inputs and outputs for each node clearly - the notes field contains execution details\n7. A new run modal that accepts a natural language prompt\n8. Dark mode color scheme throughout\n\nOutput a detailed component tree with props, signals, and data flow. Specify which solid-ui components to use (Button, Card, Dialog, Table, Badge, Tabs, Tooltip, etc)."]

    design_views [shape=box, label="Design All Views and Layouts",
        prompt="Now design the detailed layout and UX for each view in the SolidJS Attractor dashboard. For each view specify exact layout, components, and data displayed:\n\n1. **Dashboard Home**: Stats grid (total runs, success, failed, running, total tokens), recent runs table with click-to-drill-down, pipeline quick list\n2. **Pipeline List/Detail**: Pipeline cards or table, click into detail showing DOT source, run history table, pipeline-level stats, model selector, edit/delete actions\n3. **Run Detail**: Header with run ID, status badge, model, duration, token summary. Then a node execution timeline showing each node as a card/row with: node_id, label, type badge, status badge, duration, token count, attempt number. Click a node to expand and see full details.\n4. **Node Detail Panel**: Expandable or slide-out panel showing all node_log fields. The notes field should be displayed in a code/pre block as it contains prompts and LLM responses. Show failure_reason prominently if present. Show timing breakdown.\n5. **New Run Modal**: Textarea for prompt, optional model selector, submit button with loading state.\n\nUse dark mode colors: background #0a0a0f, surface #12121a, surface2 #1a1a2e, border #2a2a3e, accent #6366f1, success #22c55e, fail #ef4444, running #f59e0b, text #e2e8f0, muted #94a3b8.\n\nSpecify responsive behavior and any animations/transitions."]

    write_spec [shape=box, label="Write Full Dashboard Spec",
        prompt="Now compile everything into a comprehensive markdown specification document for the new Attractor dashboard. The document should be titled 'Attractor Dashboard Redesign — SolidJS + solid-ui' and include:\n\n1. **Overview** - What Attractor is, why we're rebuilding the dashboard\n2. **Tech Stack** - SolidJS, solid-ui components, dark mode, the existing Go REST API backend\n3. **API Reference** - All endpoints the dashboard consumes with request/response shapes\n4. **Component Architecture** - Full component tree with hierarchy, props, signals\n5. **Views & Layouts** - Detailed specs for each view (Dashboard, Pipeline List, Pipeline Detail, Run Detail, Node Detail, New Run Modal)\n6. **Color System & Theme** - Dark mode palette, CSS custom properties, typography\n7. **Data Flow** - How data flows from API to components, polling/refresh strategy, error handling\n8. **Key Interactions** - Drill-down from dashboard to pipeline to run to node, expanding node details to see inputs/outputs, starting new runs\n9. **Node Input/Output Display** - How to parse and display the notes field which contains prompts sent to LLMs and their responses, tool commands and outputs\n10. **File Structure** - Proposed project file layout for the SolidJS app\n\nOutput ONLY the markdown content, starting with the # title. Make it thorough and implementation-ready."]

    exit [shape=Msquare, label="End"]

    start -> analyze_schema
    analyze_schema -> design_architecture
    design_architecture -> design_views
    design_views -> write_spec
    write_spec -> exit
}
