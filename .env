# Attractor Environment Variables
# Copy this file to .env and fill in your values.

# Required: OpenRouter API key
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Optional: Default LLM model (OpenRouter model ID)
# Defaults to openai/gpt-4o
ATTRACTOR_MODEL=openai/gpt-4o

# Optional: Directory to store pipeline run logs
# Defaults to ~/.attractor/logs
ATTRACTOR_LOGS_DIR=~/.attractor/logs

# Optional: Path to the SQLite database
# Defaults to ~/.attractor/attractor.db
ATTRACTOR_DB_PATH=~/.attractor/attractor.db

# Optional: Web dashboard host and port
# Defaults to localhost:8080
ATTRACTOR_WEB_HOST=localhost
ATTRACTOR_WEB_PORT=8080
